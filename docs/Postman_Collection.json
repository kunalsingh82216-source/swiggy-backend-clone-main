{
  "info": {
    "name": "Swiggy Clone Backend API",
    "description": "Complete API collection for Swiggy Clone with 6 features",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@test.com\",\n  \"password\": \"123456\",\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@swiggy.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. Restaurant Search (Task 2)",
      "item": [
        {
          "name": "Search Restaurants",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/search/restaurants?q=Pizza&city=Bangalore"
          }
        },
        {
          "name": "Search with Filters",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/search/restaurants?city=Bangalore&minRating=4&isVeg=true"
          }
        },
        {
          "name": "Fuzzy Search",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/search/fuzzy?q=piza"
          }
        },
        {
          "name": "Get All Cuisines",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/search/cuisines"
          }
        },
        {
          "name": "Get All Cities",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/search/cities"
          }
        }
      ]
    },
    {
      "name": "3. Orders & Cart",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/orders/create",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [{\"name\": \"Pizza\", \"price\": 299, \"quantity\": 2}],\n  \"totalAmount\": 598,\n  \"deliveryAddress\": \"Koramangala, Bangalore\"\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/orders/my",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ]
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/orders/cancel/{{orderId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Changed my mind\"\n}"
            }
          }
        },
        {
          "name": "Track Order",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/orders/{{orderId}}/tracking",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "4. Fraud Detection (Task 1) - Admin",
      "item": [
        {
          "name": "Get Fraud Alerts",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/fraud/admin/fraud/alerts",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Get Fraud Statistics",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/fraud/admin/fraud/statistics",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Review Fraud Alert",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/fraud/admin/fraud/alerts/{{alertId}}/review",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"approve\",\n  \"adminNotes\": \"Fraud confirmed\",\n  \"restrictUser\": true\n}"
            }
          }
        }
      ]
    },
    {
      "name": "5. Surge Pricing (Task 3)",
      "item": [
        {
          "name": "Calculate Delivery Fee",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/surge/calculate-fee?distance=5"
          }
        },
        {
          "name": "Get Current Multiplier",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/surge/current-multiplier"
          }
        },
        {
          "name": "Get Surge Settings (Admin)",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/surge/settings",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Update Surge Settings (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/surge/settings",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseDeliveryFee\": 50\n}"
            }
          }
        }
      ]
    },
    {
      "name": "6. Delivery Partners (Task 4)",
      "item": [
        {
          "name": "Get Available Partners",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/delivery/available?lat=12.9716&lng=77.5946"
          }
        },
        {
          "name": "Get All Partners (Admin)",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/delivery/partners",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Update Partner Availability (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/delivery/partners/{{partnerId}}/availability",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isAvailable\": false\n}"
            }
          }
        }
      ]
    },
    {
      "name": "7. Notifications (Task 5)",
      "item": [
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/notifications",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ]
          }
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/notifications/{{notificationId}}/read",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ]
          }
        },
        {
          "name": "Update Order Status (Triggers Notification)",
          "request": {
            "method": "PUT",
            "url": "{{BASE_URL}}/api/orders/{{orderId}}/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderStatus\": \"confirmed\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "8. Recommendations (Task 6)",
      "item": [
        {
          "name": "Get My Recommendations",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/recommendations/my",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ]
          }
        },
        {
          "name": "Generate Recommendations (Admin)",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}/api/recommendations/admin/user/{{userId}}/generate",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Get Recommendation Stats (Admin)",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/recommendations/admin/stats",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:5000" },
    { "key": "userToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "alertId", "value": "" },
    { "key": "partnerId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "userId", "value": "" }
  ]
}